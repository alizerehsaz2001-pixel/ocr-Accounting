{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and authorization details",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique user UID" },
        "name": { "type": "string", "description": "Full name of the user" },
        "firstName": { "type": "string", "description": "First name of the user" },
        "lastName": { "type": "string", "description": "Last name of the user" },
        "companyName": { "type": "string", "description": "Company or business name" },
        "phone": { "type": "string", "description": "Mobile phone number of the user" },
        "jobTitle": { "type": "string", "description": "Job title or position" },
        "email": { "type": "string", "description": "Email address of the user" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "System role" },
        "status": { "type": "string", "enum": ["active", "suspended"], "description": "Account status" },
        "apiUsage": { "type": "number", "description": "Tokens or API points consumed" },
        "extraStorage": { "type": "number", "description": "Extra storage granted in gigabytes" },
        "isOnboarded": { "type": "boolean", "description": "Whether the user completed registration onboarding" }
      },
      "required": ["id", "name", "email", "role", "status"]
    },
    "Folder": {
      "title": "Folder",
      "description": "User folder for organizing scans and files",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the folder" },
        "color": { "type": "string", "description": "Color tag theme of the folder" },
        "description": { "type": "string", "description": "Description of the folder content" },
        "createdAt": { "type": "string", "description": "Folder creation ISO timestamp" }
      },
      "required": ["name", "color", "createdAt"]
    },
    "Scan": {
      "title": "Scan",
      "description": "Processed financial document with extracted transactions",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique scan ID" },
        "timestamp": { "type": "number", "description": "Epoch timestamp of upload" },
        "folder": { "type": "string", "description": "Folder classification name" },
        "file": {
          "type": "object",
          "description": "Uploaded file details",
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "size": { "type": "number" },
            "preview": { "type": "string", "description": "Base64 preview of document" },
            "status": { "type": "string" },
            "error": { "type": "string" },
            "documentType": { "type": "string" },
            "mimeType": { "type": "string" },
            "documentAnalysis": { "type": "string" },
            "tokensUsed": { "type": "number" }
          },
          "required": ["id", "name", "size", "preview", "status"]
        },
        "transactions": {
          "type": "array",
          "description": "Extracted transaction ledger items",
          "items": { "type": "object" }
        }
      },
      "required": ["id", "timestamp", "file", "transactions"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of all users registered in the system"
    },
    "users/{userId}/folders/{folderId}": {
      "schema": "Folder",
      "description": "Subcollection of custom folder categories"
    },
    "users/{userId}/scans/{scanId}": {
      "schema": "Scan",
      "description": "Subcollection of processed financial documents and invoices"
    }
  }
}
