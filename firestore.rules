rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Pillar 1)
    match /{document=**} {
      allow read, write: if false;
    }

    // Check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the user is accessing their own document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if user is ID format valid (Pillar 3)
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper for incoming document data
    function incoming() {
      return request.resource.data;
    }

    // Helper for user validation schema (Pillar 2)
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'role', 'status'])
        && data.id is string
        && data.name is string
        && data.name.size() <= 128
        && data.email is string
        && data.email.size() <= 128
        && data.role in ['admin', 'user']
        && data.status in ['active', 'suspended']
        && (!data.keys().contains('firstName') || (data.firstName is string && data.firstName.size() <= 128))
        && (!data.keys().contains('lastName') || (data.lastName is string && data.lastName.size() <= 128))
        && (!data.keys().contains('companyName') || (data.companyName is string && data.companyName.size() <= 128))
        && (!data.keys().contains('phone') || (data.phone is string && data.phone.size() <= 32))
        && (!data.keys().contains('jobTitle') || (data.jobTitle is string && data.jobTitle.size() <= 128))
        && (!data.keys().contains('isOnboarded') || (data.isOnboarded is bool));
    }

    // Helper for folder validation schema
    function isValidFolder(data) {
      return data.keys().hasAll(['name', 'color', 'createdAt'])
        && (data.keys().size() == 3 || (data.keys().size() == 4 && data.keys().contains('description')))
        && data.name is string
        && data.name.size() <= 100
        && data.color is string
        && data.color.size() <= 50
        && data.createdAt is string
        && (!data.keys().contains('description') || (data.description is string && data.description.size() <= 500));
    }

    // Helper for scan validation schema
    function isValidScan(data) {
      return data.keys().hasAll(['id', 'timestamp', 'file', 'transactions'])
        && data.id is string
        && data.id.size() <= 128
        && data.timestamp is int
        && (!data.keys().contains('folder') || (data.folder is string && data.folder.size() <= 100))
        && data.file is map
        && data.file.id is string
        && data.file.name is string
        && data.file.name.size() <= 256
        && data.file.size is int
        && data.file.preview is string
        && data.file.status is string
        && data.transactions is list;
    }

    // User Profile Rules (Pillar 4 and 6)
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      // Let's allow list only for admins
      allow list: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // Creating own user document is allowed upon first sign-in
      allow create: if isSignedIn() 
        && isOwner(userId) 
        && isValidUser(incoming())
        // Block privilege escalation: newly registered users cannot set their own role as admin (Pillar 3)
        && (incoming().role == 'user' || incoming().email == 'alizerehsaz2001@gmail.com');

      // Modifying profiles: Users can update non-privileged fields, but admins can change everything
      allow update: if isSignedIn() 
        && (
          (isOwner(userId) && incoming().role == resource.data.role && incoming().status == resource.data.status && incoming().extraStorage == resource.data.extraStorage && isValidUser(incoming())) 
          || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' && isValidUser(incoming()))
        );

      allow delete: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // Subcollections of users for custom folders (Pillar 4, 8)
      match /folders/{folderId} {
        allow read, list: if isSignedIn() && isOwner(userId);
        allow create, update: if isSignedIn() && isOwner(userId) && isValidId(folderId) && isValidFolder(incoming());
        allow delete: if isSignedIn() && isOwner(userId) && isValidId(folderId);
      }

      // Subcollections of users for scanned documents (Pillar 4, 8)
      match /scans/{scanId} {
        allow read, list: if isSignedIn() && isOwner(userId);
        allow create, update: if isSignedIn() && isOwner(userId) && isValidId(scanId) && isValidScan(incoming());
        allow delete: if isSignedIn() && isOwner(userId) && isValidId(scanId);
      }
    }

    // Simple test connection rules
    match /test/connection {
      allow read: if isSignedIn();
    }
  }
}
